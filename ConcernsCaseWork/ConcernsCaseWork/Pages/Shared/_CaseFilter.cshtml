@using System.Web
@using ConcernsCaseWork.API.Contracts.Case
@using ConcernsCaseWork.Utils.Extensions
@model ConcernsCaseWork.Models.CaseFilters

@{
    string BuildRemoveRegionLink(Region toRemove)
    {
        return $"{Url.RouteUrl(ViewContext.RouteData.Values)}?remove&SelectedRegions={(int)toRemove}";
    }

    string BuildRemoveCaseOwnerLink(string toRemove)
    {
	    return $"{Url.RouteUrl(ViewContext.RouteData.Values)}?remove&SelectedOwners={HttpUtility.UrlEncode(toRemove)}";
    }

    string BuildRemoveCaseTeamLeaderLink(string toRemove)
    {
        return $"{Url.RouteUrl(ViewContext.RouteData.Values)}?remove&SelectedTeamLeaders={HttpUtility.UrlEncode(toRemove)}";
    }

    string BuildRemoveStatusLink(CaseStatus toRemove)
    {
	    return $"{Url.RouteUrl(ViewContext.RouteData.Values)}?remove&SelectedStatuses={(int)toRemove}";
    }

    string ClearLink() => $"{Url.RouteUrl(ViewContext.RouteData.Values)}?clear=1"; /* TODO don't need the clear */

    var regions = Enum.GetValues(typeof(Region)).Cast<Region>().ToArray();
    var statuses = Enum.GetValues(typeof(CaseStatus)).Cast<CaseStatus>().Where(x => x != CaseStatus.Unknown).ToArray();
}

<div class="moj-filter">

    <div class="moj-filter__header">
        <div class="moj-filter__header-title">
            <h2 class="govuk-heading-m">Filter</h2>
        </div>
    </div>

    <div class="moj-filter__content">
        @if (Model.IsVisible)
        {
            <div class="moj-filter__selected">
                <div class="moj-filter__selected-heading">
                    <div class="moj-filter__heading-title">
                        <h2 class="govuk-heading-m">Selected filters</h2>
                    </div>
                    <div class="moj-filter__heading-action">
                        <p>
                            <a class="govuk-link govuk-link--no-visited-state" data-cy="clear-filter" href="@ClearLink()">Clear filters</a>
                        </p>
                    </div>
                </div>

                @if(Model.SelectedRegionEnums.Length > 0)
                {
                    <h3 class="govuk-heading-s govuk-!-margin-bottom-0">Regions</h3>
                    <ul class="moj-filter-tags">
                        @foreach (var region in Model.SelectedRegionEnums)
                        {
                            <li>
                                <a class="moj-filter__tag" href="@BuildRemoveRegionLink(region)">
                                    <span class="govuk-visually-hidden">Remove this filter</span>
                                    @region.Description()
                                </a>
                            </li>
                        }
                    </ul>
                }

                @if (Model.SelectedOwners.Length > 0)
                {
                    <h3 class="govuk-heading-s govuk-!-margin-bottom-0">Case owners</h3>
                    <ul class="moj-filter-tags">
                        @foreach (var owner in Model.SelectedOwners)
                        {
                            <li>
                                <a class="moj-filter__tag" href="@BuildRemoveCaseOwnerLink(owner)">
                                    <span class="govuk-visually-hidden">Remove this filter</span>
                                    @owner.FromEmailToFullName()
                                </a>
                            </li>
                        }
                    </ul>
                }

                @if (Model.SelectedTeamLeaders.Length > 0)
                {
                    <h3 class="govuk-heading-s govuk-!-margin-bottom-0">Team leader</h3>
                    <ul class="moj-filter-tags">
                        @foreach (var teamLeader in Model.SelectedTeamLeaders)
                        {
                            <li>
                                <a class="moj-filter__tag" href="@BuildRemoveCaseTeamLeaderLink(teamLeader)">
                                    <span class="govuk-visually-hidden">Remove this filter</span>
                                    @teamLeader.FromEmailToFullName()
                                </a>
                            </li>
                        }
                    </ul>
                }

                @if (Model.SelectedStatusEnums.Length > 0)
                {
                    <h3 class="govuk-heading-s govuk-!-margin-bottom-0">Statuses</h3>
                    <ul class="moj-filter-tags">
                        @foreach (var status in Model.SelectedStatusEnums)
                        {
                            <li>
                                <a class="moj-filter__tag" href="@BuildRemoveStatusLink(status)">
                                    <span class="govuk-visually-hidden">Remove this filter</span>
                                    @status.Description()
                                </a>
                            </li>
                        }
                    </ul>
                }
            </div>
        }

        <div class="moj-filter__options">
            <form method="get" class="form">
                <div class="govuk-grid-row">
                    <div class="govuk-grid-column-one-quarter">
                        <div class="govuk-form-group">
                            <fieldset class="govuk-fieldset">
                                <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
                                    Regions
                                </legend>

                                <div id="filter-regions-hint" class="govuk-hint">
                                    Select all that apply.
                                </div>

                                <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" style="max-height: 200px; overflow-y: auto; padding: 0 .5rem;">
                                    @foreach (var region in regions)
                                    {
                                        var regionValue = ((int)region).ToString();
                                        var isChecked = Model.SelectedRegionEnums.Contains(region);

                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input"
                                            id="filter-case-region-@regionValue"
                                            name="@Models.CaseFilters._selectedRegionsKey"
                                            type="checkbox"
                                            value="@regionValue"
                                            data-cy="select-case-filter-region-@region"
                                            @(isChecked ? "checked" : null) />

                                            <label class="govuk-label govuk-checkboxes__label" for="filter-case-region-@regionValue">
                                                @region.Description()
                                            </label>
                                        </div>
                                    }
                                </div>
                            </fieldset>
                        </div>
                    </div>

                    <div class="govuk-grid-column-one-quarter">
                        <div class="govuk-form-group">
                            <fieldset class="govuk-fieldset">
                                <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
                                    Case owners
                                </legend>

                                <div id="filter-owners-hint" class="govuk-hint">
                                    Select all that apply.
                                </div>

                                <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" style="max-height: 200px; overflow-y: auto; padding: 0 .5rem;">
                                    @foreach (var owner in Model.CaseOwners)
                                    {
                                        var isChecked = Model.SelectedOwners.Contains(owner);
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input"
                                                   id="filter-case-owner-@owner"
                                                   name="@Models.CaseFilters._selectedOwnerKey"
                                                   type="checkbox"
                                                   value="@owner"
                                                   data-cy="select-case-filter-pwner-@owner"
                                            @(isChecked ? "checked" : null) />
                                            <label class="govuk-label govuk-checkboxes__label" for="filter-case-owner-@owner">
                                                @owner.FromEmailToFullName()
                                            </label>
                                        </div>
                                    }
                                </div>
                            </fieldset>
                        </div>
                    </div>

                    <div class="govuk-grid-column-one-quarter">
                        <div class="govuk-form-group">
                            <fieldset class="govuk-fieldset">
                                <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
                                    Team leaders
                                </legend>

                                <div id="filter-team-leaders-hint" class="govuk-hint">
                                    Select all that apply.
                                </div>

                                <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" style="max-height: 200px; overflow-y: auto; padding: 0 .5rem;">
                                    @foreach (var teamLeader in Model.TeamLeaders)
                                    {
                                        var isChecked = Model.SelectedTeamLeaders.Contains(teamLeader);
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input"
                                                   id="filter-case-team-leader-@teamLeader"
                                                   name="@Models.CaseFilters._selectedCaseTeamLeaderKey"
                                                   type="checkbox"
                                                   value="@teamLeader"
                                                   data-cy="select-case-filter-team-leader-@teamLeader"
                                            @(isChecked ? "checked" : null) />
                                            <label class="govuk-label govuk-checkboxes__label" for="filter-case-team-leader-@teamLeader">
                                                @teamLeader.FromEmailToFullName()
                                            </label>
                                        </div>
                                    }
                                </div>
                            </fieldset>
                        </div>
                    </div>

                    <div class="govuk-grid-column-one-quarter">
                        <div class="govuk-form-group">
                            <fieldset class="govuk-fieldset">
                                <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
                                    Statuses
                                </legend>

                                <div id="filter-statuses-hint" class="govuk-hint">
                                    Select all that apply.
                                </div>

                                <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" style="max-height: 200px; overflow-y: auto; padding: 0 .5rem;">
                                    @foreach (var status in statuses)
                                    {
                                        var statusValue = ((int)status).ToString();
                                        var isChecked = Model.SelectedStatusEnums.Contains(status);
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input"
                                                   id="filter-case-status-@statusValue"
                                                   name="@Models.CaseFilters._selectedStatusesKey"
                                                   type="checkbox"
                                                   value="@statusValue"
                                                   data-cy="select-case-filter-status-@status"
                                            @(isChecked ? "checked" : null) />
                                            <label class="govuk-label govuk-checkboxes__label" for="filter-case-status-@statusValue">
                                                @status.Description()
                                            </label>
                                        </div>
                                    }
                                </div>
                            </fieldset>
                        </div>
                    </div>
                </div>

                <button class="govuk-button govuk-!-margin-top-4"
                        data-module="govuk-button"
                        data-test-id="submit-button"
                        data-cy="select-case-filter-apply">
                    Apply filters
                </button>
            </form>
        </div>
    </div>
</div>
